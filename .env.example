# Database (Neon)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Auth
AUTH_SECRET=your-32-char-secret-here
AUTH_URL=http://localhost:3000

# OAuth — Google (console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (github.com/settings/developers → OAuth Apps)
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# AI — Production (xAI Grok + Cohere embeddings)
COHERE_API_KEY=co-...
XAI_API_KEY=xai-...
EMBEDDING_DIMENSIONS=1536

# AI — Test Providers (NVIDIA NIM for chat)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_CHAT_MODEL=nvidia/glm-4-9b-chat

# Toggle: "test" = NIM chat, "production" = xAI + Cohere
AI_PROVIDER_MODE=production

# Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
